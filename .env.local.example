# Taskvia — .env.local.example
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ===== Upstash Redis (required) =====
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ===== ntfy self-host notification =====
# Both NTFY_URL and NTFY_TOPIC must be set to enable push notifications.
# Set NTFY_USER / NTFY_PASS if the ntfy server requires Basic authentication.
NTFY_URL=https://ntfy.example.com
NTFY_TOPIC=taskvia-approval-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NTFY_USER=taskvia
NTFY_PASS=your-ntfy-password

# ===== Approval token settings =====
# TTL (seconds) for one-time tokens used in ntfy action buttons (default: 900)
APPROVAL_TOKEN_TTL_SECONDS=900
# Base URL used to build approve/deny token URLs in ntfy notifications.
# Set to your deployment URL or ngrok URL during local E2E testing.
TASKVIA_BASE_URL=https://taskvia.vercel.app

# ===== API authentication =====
# Bearer token for protecting /api/* endpoints.
# Always set in production; omit only for local development.
TASKVIA_TOKEN=your-api-token

# ===== GitHub integration (optional) =====
# PAT with contents:write scope — required only for /api/flush-logs.
GITHUB_TOKEN=ghp_xxxx
